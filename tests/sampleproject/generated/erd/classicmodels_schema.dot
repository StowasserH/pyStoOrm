digraph database_schema
{
    rankdir=LR;
    node [shape=plaintext];
    edge [arrowhead=crow];

    
    customers [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2"><B>customers</B></TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>customerNumber (PK)</B></TD><TD ALIGN="LEFT">int</TD></TR>
                
                <TR><TD ALIGN="LEFT">customerName</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">contactLastName</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">contactFirstName</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">phone</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">addressLine1</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">addressLine2</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">city</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">state</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">postalCode</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">country</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT"><I>salesRepEmployeeNumber (FK)</I></TD><TD ALIGN="LEFT">int</TD></TR>
                
                <TR><TD ALIGN="LEFT">creditLimit</TD><TD ALIGN="LEFT">float</TD></TR>
        </TABLE>
    >];
    
    employees [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2"><B>employees</B></TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>employeeNumber (PK)</B></TD><TD ALIGN="LEFT">int</TD></TR>
                
                <TR><TD ALIGN="LEFT">lastName</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">firstName</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">extension</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">email</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT"><I>officeCode (FK)</I></TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT"><I>reportsTo (FK)</I></TD><TD ALIGN="LEFT">int</TD></TR>
                
                <TR><TD ALIGN="LEFT">jobTitle</TD><TD ALIGN="LEFT">str</TD></TR>
        </TABLE>
    >];
    
    offices [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2"><B>offices</B></TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>officeCode (PK)</B></TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">city</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">phone</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">addressLine1</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">addressLine2</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">state</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">country</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">postalCode</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">territory</TD><TD ALIGN="LEFT">str</TD></TR>
        </TABLE>
    >];
    
    orderdetails [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2"><B>orderdetails</B></TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>orderNumber (PK)</B></TD><TD ALIGN="LEFT">int</TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>productCode (PK)</B></TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">quantityOrdered</TD><TD ALIGN="LEFT">int</TD></TR>
                
                <TR><TD ALIGN="LEFT">priceEach</TD><TD ALIGN="LEFT">float</TD></TR>
                
                <TR><TD ALIGN="LEFT">orderLineNumber</TD><TD ALIGN="LEFT">int(${column.length})</TD></TR>
        </TABLE>
    >];
    
    orders [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2"><B>orders</B></TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>orderNumber (PK)</B></TD><TD ALIGN="LEFT">int</TD></TR>
                
                <TR><TD ALIGN="LEFT">orderDate</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">requiredDate</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">shippedDate</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">status</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">comments</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT"><I>customerNumber (FK)</I></TD><TD ALIGN="LEFT">int</TD></TR>
        </TABLE>
    >];
    
    payments [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2"><B>payments</B></TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>customerNumber (PK)</B></TD><TD ALIGN="LEFT">int</TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>checkNumber (PK)</B></TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">paymentDate</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">amount</TD><TD ALIGN="LEFT">float</TD></TR>
        </TABLE>
    >];
    
    productlines [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2"><B>productlines</B></TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>productLine (PK)</B></TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">textDescription</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">htmlDescription</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">image</TD><TD ALIGN="LEFT">bytes</TD></TR>
        </TABLE>
    >];
    
    products [label=<
        <TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0">
            <TR><TD COLSPAN="2"><B>products</B></TD></TR>
                
                <TR><TD ALIGN="LEFT"><B>productCode (PK)</B></TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">productName</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT"><I>productLine (FK)</I></TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">productScale</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">productVendor</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">productDescription</TD><TD ALIGN="LEFT">str</TD></TR>
                
                <TR><TD ALIGN="LEFT">quantityInStock</TD><TD ALIGN="LEFT">int(${column.length})</TD></TR>
                
                <TR><TD ALIGN="LEFT">buyPrice</TD><TD ALIGN="LEFT">float</TD></TR>
                
                <TR><TD ALIGN="LEFT">MSRP</TD><TD ALIGN="LEFT">float</TD></TR>
        </TABLE>
    >];

    
            
            employees -> customers [label="salesRepEmployeeNumber"];
    
            
            offices -> employees [label="officeCode"];
            
            employees -> employees [label="reportsTo"];
    
    
            
            products -> orderdetails [label="productCode"];
            
            orders -> orderdetails [label="orderNumber"];
    
            
            customers -> orders [label="customerNumber"];
    
            
            customers -> payments [label="customerNumber"];
    
    
            
            productlines -> products [label="productLine"];

    graph [label="/home/stowasserh/Nextcloud/share/work/pyStoOrm/tests/sampleproject/classicmodels.db Database Schema", labelloc="top", fontsize="16"];
}
