  private function mkInsert($connection) {
    $sql = "INSERT INTO ". $this->getDbStr()."map (" . self::SQLSETPREP . ",create_date) VALUES (?,?,?,?,?,?,?,?,?,?,?,?,now() )";
    if (! $connection->preparedInsert_map=$connection->prepare($sql)) throw new EDbObject(10011);;
