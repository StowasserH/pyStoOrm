  /**
   * Lädt den aktuellen Datensatz aus der DB.
   * @param int map_id
   */
  public function read( $map_id,$conn , $isKey=false){
    if (is_string( $map_id)){
      $sql = $this->getSQLGET().' WHERE '.$map_id;
      $stmt =$conn->query($sql);
      $result = $stmt->setFetchMode(PDO::FETCH_NUM);
      $result = $stmt->fetchAll();
    }else{
      if ( ! isset ($conn->preparedGetbyID_map)){
        $sql = $this->getSQLGET().' WHERE map_id=?';
        $conn->preparedGetbyID_map=$conn->prepare($sql);
        $conn->preparedGetbyID_map->setFetchMode(PDO::FETCH_NUM);
      }
      $conn->preparedGetbyID_map->bindParam(1, $map_id, PDO::PARAM_INT);
      if ( ! $conn->preparedGetbyID_map->execute()){
        throw new EDbObject (10009, $map_id);
      }
      $result=$conn->preparedGetbyID_map->fetchAll();
    }
    if (count($result)==0){
      throw new EDbObject (10007,$map_id);
    }elseif (count($result)>1){
      throw new EDbObject (10008,$map_id);
    }
    $this->getFromSql( $result[0]);
  }
  /**
   * Hilfsfunktion zum Aufbau des Optimistik-lock
   */
  private function mkOptitest($connection) {
    $sql = "SELECT map_id FROM ". $this->getDbStr()."map WHERE map_id=? AND changed=?";
    $connection->preparedOptitest_map=$connection->prepare($sql);
    $connection->preparedOptitest_map->setFetchMode(PDO::FETCH_NUM);
  }
  /**
   * Hilfsfunktion zum Aufbau des Optimistik-lock
   */
  private function checkLock($dbid,$timestamp,$connection){
    if( ! $this->skipOptimisticLock){
      if ( ! isset ($connection->preparedOptitest_map)) $this->mkOptitest($connection);
      $connection->preparedOptitest_map->bindParam(1, $dbid, PDO::PARAM_INT);
      $connection->preparedOptitest_map->bindParam(2, $timestamp , PDO::PARAM_STR  );
      $connection->preparedOptitest_map->execute();
      if ( count( $connection->preparedOptitest_map->fetchAll() ) != 1 ){
        throw new EDbObject(10010);
      }
    }
  }
