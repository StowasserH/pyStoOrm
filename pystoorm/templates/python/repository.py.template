  /**
   * Schreibt den Datensatz in die Datenbank
   * @param connection ist die Connection in die geschrieben wird!
   */
  public function write($connection)
  {
    if ( ! $this->isChanged() ) return;
    if( is_null($connection)){
      throw new EDbObject(10013);
    }
    $dbid=$this->getDBID();
    $locked=false;
    $error=null;
    try{
      // das Optimistic-Locking:
      $timestamp=$this->getChanged(new SqlDateModifier());
      if ( strlen($timestamp) > 1 && $dbid != 0){
        $locked=true;
        if ( ! isset ($connection->preparedLockInno_map)){
          $sql='SELECT map_id FROM '.$this->getDbStr( ) .'map WHERE map_id=? FOR UPDATE';
          if (! $connection->preparedLockInno_map=$connection->prepare($sql)) throw new EDbObject(10012);
          $connection->preparedLockInno_map->setFetchMode(PDO::FETCH_NUM);
        }
        $connection->preparedLockInno_map->bindParam(1, $dbid, PDO::PARAM_INT);
        $connection->preparedLockInno_map->execute();
        $dummy = $connection->preparedLockInno_map->fetchAll();
        $dummy=null;
        $stmt=null;
        $this->checkLock($dbid,$timestamp,$connection);
      }
      if ($this->getLe()==0)
        {$this->einfuegen($connection);}
      if ( $dbid == 0 ){
        if ( ! isset ($connection->preparedInsert_map)) $this->mkInsert($connection);
        $bindto=$connection->preparedInsert_map;
      } else {
        if ( ! isset ($connection->preparedUpdate_map)) $this->mkUpdate($connection);
        $bindto=$connection->preparedUpdate_map;
      }
      $val=$this->getMap_id();
      if (is_null($val)) $val=0;
      $bindto->bindValue(1,$val,PDO::PARAM_INT);
      $val=$this->getMap_pattern_id();
      $bindto->bindValue(2, $val,is_null($val)?PDO::PARAM_NULL:PDO::PARAM_INT);
      $val=$this->getMap_piece_id();
      $bindto->bindValue(3, $val,is_null($val)?PDO::PARAM_NULL:PDO::PARAM_INT);
      $val=$this->getMap_type_id();
      $bindto->bindValue(4, $val,is_null($val)?PDO::PARAM_NULL:PDO::PARAM_INT);
      $val=$this->getState();
      if (empty($val)) $val='Angezeigt';
      $bindto->bindValue(5,$val,PDO::PARAM_STR);
      $val=$this->getWastebasket();
      if (empty($val)) $val='Nein';
      $bindto->bindValue(6,$val,PDO::PARAM_STR);
      $dat=$this->getPublish_from(new SqlDateModifier());
      if ( strlen( $dat )<2)
      {
        $dat=DbObject::MINDATE;
      }
      $bindto->bindValue(7,$dat , PDO::PARAM_STR);
      $dat=$this->getPublish_to(new SqlDateModifier());
      if ( strlen( $dat )<2)
      {
        $dat=DbObject::MAXDATE;
      }
      $bindto->bindValue(8,$dat , PDO::PARAM_STR);
      $val=$this->getRootid();
      if (is_null($val)) $val=0;
      $bindto->bindValue(9,$val,PDO::PARAM_INT);
      $val=$this->getLe();
      if (is_null($val)) $val=0;
      $bindto->bindValue(10,$val,PDO::PARAM_INT);
      $val=$this->getRe();
      if (is_null($val)) $val=0;
      $bindto->bindValue(11,$val,PDO::PARAM_INT);
      $val=$this->getOriginal();
      if (empty($val)) $val='Nein';
      $bindto->bindValue(12,$val,PDO::PARAM_STR);
      if ( $dbid == 0 ){
        $bindto->execute();
        $this->temp_id=$connection->lastInsertId();
        $this->daten[self::posMap_id]= $this->temp_id;
      } else {
        $bindto->bindParam(13, $dbid,PDO::PARAM_INT);
        $bindto->execute();
      }
      if ($this->getRootid()==0 && $this->getLe()==1){
        $connection->exec("UPDATE ". $this->getDbStr()."map SET rootid=map_id WHERE map_id=".$this->getDBID());
        $this->setRootid($this->getDBID());
      }
      $this->ObChanged=false;
    }catch(Exception $e){
       $error=$e;
    }
    if($locked==true){
      //nothing to do in innodb.
    }
    if ($error){ throw($error);}
    $this->skipOptimisticLock=false;
  }
