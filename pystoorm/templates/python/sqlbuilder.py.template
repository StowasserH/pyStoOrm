        Returns:
            Dictionary: {column_name: type_char}
        """
        types_str = ${camel_case(table_name)}Builder.types()
        columns = ${camel_case(table_name)}Builder.columns()
        return {col: types_str[i] for i, col in enumerate(columns)}
